# ============================================================
# RoomRent — Variables de entorno requeridas en producción
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# Nunca cometas el .env al repositorio.
# ============================================================

# ── Spring Boot ──────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── MongoDB ──────────────────────────────────────────────────
# URI con credenciales. El host "mongo" es el nombre del servicio
# en docker-compose. Cámbialo si usas MongoDB externo.
SPRING_MONGODB_URI=mongodb://roomrent:CAMBIAR_PASSWORD@mongo:27017/room

# ── JWT ──────────────────────────────────────────────────────
# Secreto Base64 para firmar tokens JWT (mínimo 512 bits).
# Genera uno nuevo con: openssl rand -base64 64
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=CAMBIAR_POR_SECRETO_BASE64_DE_64_BYTES

# ── Correo electrónico ────────────────────────────────────────
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=tu-cuenta@gmail.com
# Contraseña de aplicación Gmail (16 caracteres, sin espacios).
# Genera una en: Google Account → Seguridad → Contraseñas de aplicaciones
SPRING_MAIL_PASSWORD=xxxx xxxx xxxx xxxx
JHIPSTER_MAIL_BASE_URL=https://room-rent.xyz

# ── SMTP JavaMail (Gmail STARTTLS requerido en puerto 587) ───
# Docker Compose traduce estas variables al nombre interno de Spring Boot:
#   SPRING_MAIL_SMTP_STARTTLS_ENABLE → spring.mail.properties.mail.smtp.starttls.enable
# No cambies estos valores salvo que uses un SMTP distinto a Gmail.
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_AUTH=true

# ── React portal (Vite build) ────────────────────────────────
# Vacío = misma origin (recomendado: Nginx hace el proxy al Spring Boot)
# Llénalo solo si el API vive en un subdominio diferente.
VITE_API_BASE=

# ── MongoDB container (docker-compose) ───────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=CAMBIAR_PASSWORD_ROOT
MONGO_INITDB_DATABASE=room
MONGO_USERNAME=roomrent
MONGO_PASSWORD=CAMBIAR_PASSWORD
