# SMTP Configuration for Development
# Copy this file to .env and fill in your values
# .env is in .gitignore and should NEVER be committed

# Gmail SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Gmail account (use App Password, NOT account password)
# Get App Password from: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-16-chars

# Sender email
MAIL_FROM=noreply-room@gmail.com

# Optional: Logging level for mail debugging
LOGGING_LEVEL_SPRING_MAIL=DEBUG
LOGGING_LEVEL_COM_ROOMRENT_SERVICE=DEBUG
